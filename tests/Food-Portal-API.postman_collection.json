  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-add authorization header if token exists",
          "if (pm.variables.get('token')) {",
          "  pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + pm.variables.get('token') });",
          "}",
          "",
          "// Set Content-Type for JSON requests",
          "if (!pm.request.headers.has('Content-Type')) {",
          "  pm.request.headers.add({ key: 'Content-Type', value: 'application/json' });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-save IDs from responses",
          "const response = pm.response.json();",
          "",
          "// Save user ID from sign-up/sign-in",
          "if (response.data && response.data.user && response.data.user.id) {",
          "  pm.variables.set('userId', response.data.user.id);",
          "}",
          "",
          "// Save provider profile ID",
          "if (response.data && response.data.id && pm.request.url.path.includes('provider-profiles')) {",
          "  pm.variables.set('providerId', response.data.id);",
          "}",
          "",
          "// Save meal ID",
          "if (response.data && response.data.id && pm.request.url.path.includes('meals')) {",
          "  pm.variables.set('mealId', response.data.id);",
          "}",
          "",
          "// Save category ID",
          "if (response.data && response.data.id && pm.request.url.path.includes('categories')) {",
          "  pm.variables.set('categoryId', response.data.id);",
          "}",
          "",
          "// Save location ID",
          "if (response.data && response.data.id && pm.request.url.path.includes('locations')) {",
          "  pm.variables.set('locationId', response.data.id);",
          "}",
          "",
          "// Save order ID",
          "if (response.data && response.data.id && pm.request.url.path.includes('orders')) {",
          "  pm.variables.set('orderId', response.data.id);",
          "}",
          "",
          "// Save review ID",
          "if (response.data && response.data.id && pm.request.url.path.includes('reviews')) {",
          "  pm.variables.set('reviewId', response.data.id);",
          "}",
          "",
          "// Save token from sign-in",
          "if (response.data && response.data.session && response.data.session.token) {",
          "  pm.variables.set('token', response.data.session.token);",
          "}",
          "if (response.data && response.data.token) {",
          "  pm.variables.set('token', response.data.token);",
          "}",
          "",
          "// Log response for debugging",
          "console.log('Response:', JSON.stringify(response, null, 2));"
        ]
      }
    }
  ],
