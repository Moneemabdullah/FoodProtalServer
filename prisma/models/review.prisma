model Review {
  id        String   @id @default(uuid())
  userId    String
  mealId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mealId])
  @@index([rating])
}
