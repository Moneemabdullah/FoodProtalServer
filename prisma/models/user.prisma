model User {
    id            String   @id @default(uuid())
    name          String
    email         String   @unique
    emailVerified Boolean
    image         String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    accounts         Account[]
    sessions         Session[]
    providerProfiles ProviderProfile[]
    orders           Order[]
    reviews          Review[]
}

model Session {
    id        String   @id
    expiresAt DateTime
    token     String   @unique
    createdAt DateTime
    updatedAt DateTime
    ipAddress String?
    userAgent String?
    userId    String

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
    id         String   @id
    accountId  String
    providerId String
    userId     String
    password   String?
    type       String
    createdAt  DateTime
    updatedAt  DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
